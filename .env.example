# Copie para .env e ajuste. Em produção, configure no painel do Railway.

# 1 = desenvolvimento (nunca em produção)
DEBUG=1

# Obrigatório em produção: string longa e aleatória
# SECRET_KEY=

# Local: usa postgres://localhost/crm_vo_testa por padrão se não definido
# DATABASE_URL=postgres://usuario:senha@host:5432/banco

# Produção: domínios separados por vírgula
# ALLOWED_HOSTS=crm.pousadavotesta.com.br
# CSRF_TRUSTED_ORIGINS=https://crm.pousadavotesta.com.br

# Frigobar: 1 = check-out só após conferência (padrão); 0 = desliga o guard
# FRIGOBAR_BLOQUEAR_CHECKOUT=1

# Pagamentos — gateway: simulado (padrão) | safrapay
# PAGAMENTOS_GATEWAY=simulado

# Safrapay — 3 campos de developers.safrapay.com.br/keys (nunca commitar valores reais)
# SAFRAPAY_ENV=hml
# SAFRAPAY_ID=
# SAFRAPAY_CODIGO_ATIVACAO=
# SAFRAPAY_TOKEN=

# E-mail (Zoho) — use senha de app, não a senha de login
# EMAIL_HOST=smtp.zoho.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=naoresponda@pousadavotesta.com.br
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Pousada Vô Testa <naoresponda@pousadavotesta.com.br>
# URL pública (links no e-mail de reserva)
# SITE_PUBLIC_URL=https://www.pousadavotesta.com.br
